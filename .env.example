# === Обязательно ===
# Email для регистрации в Let's Encrypt (должен быть реальный домен, не IP)
LEGO_EMAIL=you@example.com

# === SOCKS5 авторизация ===
GOST_USER=proxy
# Оставьте пустым — install.sh сгенерирует случайный пароль
GOST_PASSWORD=

# === Сеть ===
# Публичный IP VPS. Пусто = автоопределение (curl ifconfig.me)
SERVER_IP=

# Порт прокси на хосте
GOST_PORT=1443

# === Режим маршрута выхода ===
# direct (по умолчанию) или chain
# Состояние хранится в CHAIN_MODE_FILE и переключается скриптами chain-on/off.
CHAIN_MODE_FILE=state/mode

# Применение изменений конфига: sighup (без рестарта контейнера) или restart
GOST_RELOAD_MODE=sighup

# === Настройки hop (режим chain) ===
HOP_SERVER_IP=5.8.34.74
HOP_GOST_PORT=1443
HOP_GOST_USER=hop
HOP_GOST_PASSWORD=

# === Обычно менять не нужно ===
GOST_CONTAINER=gost-socks5
GOST_IMAGE=gogost/gost:latest
LEGO_PATH=/etc/lego/gost-socks-proxy
CRON_SCHEDULE="0 3,15 * * *"
