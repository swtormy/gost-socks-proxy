# === Обязательно ===
# Email для регистрации в Let's Encrypt (должен быть реальный домен, не IP)
LEGO_EMAIL=you@example.com

# === SOCKS5 авторизация ===
GOST_USER=proxy
# Оставьте пустым — install.sh сгенерирует случайный пароль
GOST_PASSWORD=

# === Сеть ===
# Публичный IP VPS. Пусто = автоопределение (curl ifconfig.me)
SERVER_IP=

# Порт прокси на хосте
GOST_PORT=1443

# === Обычно менять не нужно ===
GOST_CONTAINER=gost-socks5
GOST_IMAGE=gogost/gost:latest
LEGO_PATH=/etc/lego/gost-socks-proxy
CRON_SCHEDULE="0 3,15 * * *"
